# gitattributes
# 统一换行符为 LF（GitHub 标准）
* text=auto eol=lf

# Gradle
*.gradle text diff
*.gradle.kts text diff
gradlew text eol=lf
gradlew.bat text eol=crlf

# Android
*.kt text diff
*.kts text diff
*.xml text diff
*.properties text diff

# 二进制文件
*.png binary
*.jpg binary
*.jks binary
*.jar binary
*.so binary
*.aar binary
